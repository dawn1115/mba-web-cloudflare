{
  "name": "mba-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "db:migrate:local": "wrangler d1 migrations apply mba-web-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply mba-web-db --remote",
    "db:generate": "prisma generate",
    "cf-typegen": "wrangler types"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed/admin.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.4.0",
    "@prisma/adapter-d1": "^7.5.0",
    "@prisma/client": "^6.19.2",
    "lucide-react": "^0.577.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "esbuild": "^0.27.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "prisma": "^6.19.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.76.0"
  }
}
